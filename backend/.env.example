# Local default: SQLite, no account required.
DATABASE_URL=sqlite+aiosqlite:///./lecturemap.db
# Production option: Supabase Postgres free tier https://supabase.com/pricing
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.project.supabase.co:5432/postgres

# File storage option: Supabase Storage free tier https://supabase.com/pricing
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=lecture-files

# Knowledge graph option: Neo4j AuraDB Free https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Queue option: Upstash Redis free tier https://upstash.com/pricing
REDIS_URL=
USE_CELERY=false

# AI extraction: Google AI Studio free tier https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=replace-with-a-long-random-production-secret

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
